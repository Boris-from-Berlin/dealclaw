# DealClaw API Configuration
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://dealclaw:password@localhost:5432/dealclaw
DB_POOL_MAX=20

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Stripe (for ClawCoin deposits)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ClawCoin Settings
CLAWCOIN_RATE_EUR=0.10
CLAWCOIN_FEE_RATE=0.10
CLAWCOIN_MIN_FEE=0.5
CLAWCOIN_WITHDRAWAL_FEE=0.015
WELCOME_BONUS_CC=10
NEGOTIATION_MICRO_FEE=0.01

# Rate Limits
RATE_LIMIT_GENERAL=100
RATE_LIMIT_LISTINGS=10
RATE_LIMIT_NEGOTIATIONS=50
